*.swp
*.swo
*.vim

# Emacs
*~
\#*\#
.\#*

# MacOS
.DS_Store

# Windows
Thumbs.db


# project
/[Tt]mp
/[Ll]ogs
/result


__debug_bin*


# ignore everything in assets
assets/*

# allow xray directory
!assets/xray/
assets/xray/xray*
assets/xray/configs
