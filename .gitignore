
# Ignore all .txt files
*.txt


# ------------------------------------
# Go build files
# ------------------------------------
/bin/
/build/
/dist/
/out/
/coverage/
/tmp/

# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Go modules
/go.sum
/vendor/

# Logs
*.log

# Dependency directories
pkg/
**/pkg/

# Local environment files
.env
*.local

# ------------------------------------
# IDE / Editor ignores
# ------------------------------------

# VSCode
.vscode/
.history/

# JetBrains IDEs (GoLand, IntelliJ IDEA, etc.)
.idea/
*.iml
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

